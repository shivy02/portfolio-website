# WakaTime API Key
# Get your API key from: https://wakatime.com/settings/account
WAKATIME_API_KEY=your_wakatime_api_key_here

# Spotify API Credentials
# Follow guide: https://leerob.io/blog/spotify-api-nextjs
SPOTIFY_CLIENT_ID=id
SPOTIFY_CLIENT_SECRET=secret
SPOTIFY_REFRESH_TOKEN=your_spotify_refresh_token

# GitHub API Credentials
# Get your Personal Access Token from: https://github.com/settings/tokens
# Required scopes: read:user (or no scopes for public contributions only)
GITHUB_TOKEN=your_github_personal_access_token
GITHUB_USERNAME=your_github_username
# Repo shown in the "Open Source" section as "owner/name".
# Optional — defaults to shivy02/portfolio-website.
GITHUB_REPO=owner/repo-name
